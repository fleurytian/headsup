<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>aps-environment</key>
    <string>development</string>
    <key>com.apple.developer.applesignin</key>
    <array>
        <string>Default</string>
    </array>
    <!-- Communication Notifications: lets the NSE upgrade pushes to the
         iMessage-style sender-avatar layout. Bark uses this and it's how
         their banner shows the agent's avatar on the left. Apple wants this
         pre-approved for App Store distribution; Xcode's automatic dev
         provisioning lets it through for Debug builds. -->
    <key>com.apple.developer.usernotifications.communication</key>
    <true/>
    <!-- Time Sensitive interruption level — pushes can break through Focus.
         Required when payload sets aps.interruption-level=timeSensitive. -->
    <key>com.apple.developer.usernotifications.time-sensitive</key>
    <true/>
    <!-- App Group: lets the NSE persist incoming messages (plist) into a
         shared container that the main app + Widget read on launch/refresh.
         Pattern from Bark; avoids the 0xdead10cc SQLite multi-process crash
         you get from sharing a real DB across host + extension. -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.md.headsup</string>
    </array>
</dict>
</plist>
