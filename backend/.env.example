# Database — use sqlite for local dev, postgresql for production
DATABASE_URL=sqlite:///./ask.db
# DATABASE_URL=postgresql://user:password@localhost/ask

# Security — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret

# APNs (Apple Push Notification service)
# Get these from your Apple Developer account
APNS_KEY_ID=YOUR_KEY_ID_HERE
APNS_TEAM_ID=YOUR_TEAM_ID_HERE
APNS_PRIVATE_KEY_PATH=./apns_key.p8
APNS_BUNDLE_ID=com.yourcompany.headsup
APNS_PRODUCTION=false

# App
BASE_URL=http://localhost:8000
APP_NAME=HeadsUp
